// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String?
  lastName  String?
  phone     String?
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
  addresses Address[]

  @@map("users")
}

model Address {
  id       String @id @default(cuid())
  userId   String
  fullName String
  phone    String
  address  String
  city     String
  state    String
  country  String @default("Nigeria")
  isDefault Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

model Product {
  id          String      @id
  name        String
  description String
  price       Int         // Price in kobo (₦1 = 100 kobo)
  category    Category
  images      String[]    // Array of image URLs
  sizes       String[]    // Available sizes
  colors      String[]    // Available colors
  featured    Boolean     @default(false)
  isDrop      Boolean     @default(false)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  inventory ProductInventory[]
  orderItems OrderItem[]
  ratings   ProductRating[]

  @@map("products")
}

model ProductInventory {
  id        String @id @default(cuid())
  productId String
  size      String
  color     String
  quantity  Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size, color])
  @@map("product_inventory")
}

model Order {
  id            String      @id @default(cuid())
  userId        String?
  email         String
  total         Int         // Total in kobo
  status        OrderStatus @default(PENDING)
  paymentId     String?     // Paystack payment reference
  paymentStatus PaymentStatus @default(PENDING)

  // Shipping info
  shippingAddressId String?
  shippingAddress   Address? @relation(fields: [shippingAddressId], references: [id])

  // Manual shipping info for guest orders
  shippingName     String?
  shippingPhone    String?
  shippingAddressText String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Int    // Price at time of order in kobo
  size      String
  color     String

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model ProductRating {
  id        String @id @default(cuid())
  productId String
  userId    String
  rating    Int    // 1-5 stars
  review    String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@map("product_ratings")
}

enum Role {
  ADMIN
  CUSTOMER
}

enum Category {
  TSHIRT
  HOODIE
  LIMITED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}
